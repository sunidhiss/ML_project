      ],
      "source": [
        "# ================================================================\n",
        "#  DISEASE OUTBREAK PREDICTION — Improved Full Pipeline\n",
        "#  Improvements: Feature Engineering + Better Models + K-Fold CV\n",
        "#                + Confusion Matrices + Class Imbalance Handling\n",
        "# ================================================================\n",
        "\n",
        "# ── 1. Upload & Load ─────────────────────────────────────────\n",
        "from google.colab import files\n",
        "uploaded = files.upload()\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "df = pd.read_excel('Final_data.xlsx')\n",
        "df['Cases'] = pd.to_numeric(df['Cases'], errors='coerce')\n",
        "print(\"Shape:\", df.shape)\n",
        "print(df.head())\n",
        "\n",
        "# ── 2. Feature Engineering ───────────────────────────────────\n",
        "# Sort so lag features are computed correctly per district over time\n",
        "df = df.sort_values(['district', 'year', 'mon', 'day']).reset_index(drop=True)\n",
        "\n",
        "# Lag features — captures how many cases existed in prior weeks\n",
        "df['Cases_lag1'] = df.groupby('district')['Cases'].shift(1)\n",
        "df['Cases_lag2'] = df.groupby('district')['Cases'].shift(2)\n",
        "\n",
        "# Rolling mean — smoothed trend of last 3 records per district\n",
        "df['Cases_rolling_mean'] = df.groupby('district')['Cases'].transform(\n",
        "    lambda x: x.rolling(3, min_periods=1).mean()\n",
        ")\n",
        "\n",
        "# Death rate — more meaningful than raw death count\n",
        "df['Death_Rate'] = df['Deaths'] / (df['Cases'] + 1)\n",
        "\n",
        "# Interaction feature — hot + wet = higher disease risk\n",
        "df['Temp_Preci'] = df['Temp'] * df['preci']\n",
        "\n",
        "# Encode disease type as a numeric feature\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "le = LabelEncoder()\n",
        "df['Disease_enc'] = le.fit_transform(df['Disease'].fillna('Unknown'))\n",
        "\n",
        "print(\"\\nEngineered features added: Cases_lag1, Cases_lag2, Cases_rolling_mean,\")\n",
        "print(\"Death_Rate, Temp_Preci, Disease_enc\")\n",
        "\n",
        "# ── 3. Target Variable ───────────────────────────────────────\n",
        "threshold = 10\n",
        "df['Outbreak'] = (df['Cases'] > threshold).astype(int)\n",
        "\n",
        "print(f\"\\nClass distribution (threshold = {threshold} cases):\")\n",
        "vc = df['Outbreak'].value_counts()\n",
        "print(f\"  Outbreak (1): {vc[1]} ({vc[1]/len(df)*100:.1f}%)\")\n",
        "print(f\"  No Outbreak (0): {vc[0]} ({vc[0]/len(df)*100:.1f}%)\")\n",
        "\n",
        "# ── 4. Feature Matrix ────────────────────────────────────────\n",
        "features = [\n",
        "    'Deaths', 'Temp', 'preci', 'LAI', 'Latitude', 'Longitude',\n",
        "    'Cases_lag1', 'Cases_lag2', 'Cases_rolling_mean',\n",
        "    'Death_Rate', 'Temp_Preci', 'Disease_enc', 'mon', 'day'\n",
        "]\n",
        "\n",
        "X = df[features].copy()\n",
        "for col in features:\n",
        "    X[col] = pd.to_numeric(X[col], errors='coerce')\n",
        "X = X.fillna(X.mean())\n",
        "y = df['Outbreak']\n",
        "\n",
        "print(f\"\\nFeature matrix shape: {X.shape}\")\n",
        "\n",
        "# ── 5. Imports ───────────────────────────────────────────────\n",
        "from sklearn.model_selection import (StratifiedKFold, cross_validate,\n",
        "                                     cross_val_predict)\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.pipeline import Pipeline\n",
        "from sklearn.metrics import (accuracy_score, precision_score, recall_score,\n",
        "                              f1_score, roc_auc_score, confusion_matrix)\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# ── 6. K-Fold Setup ──────────────────────────────────────────\n",
        "K = 10\n",
        "skf = StratifiedKFold(n_splits=K, shuffle=True, random_state=42)\n",
        "# StratifiedKFold ensures each fold has the same 88/12 class ratio\n",
        "\n",
        "# ── 7. Define Models ─────────────────────────────────────────\n",
        "logreg = Pipeline([\n",
        "    ('scaler', StandardScaler()),\n",
        "    ('clf', LogisticRegression(max_iter=1000, class_weight='balanced'))\n",
        "])\n",
        "# class_weight='balanced' compensates for 88/12 imbalance automatically\n",
        "\n",
        "rf = RandomForestClassifier(\n",
        "    n_estimators=200,\n",
        "    max_depth=10,\n",
        "    class_weight='balanced',\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "gb = GradientBoostingClassifier(\n",
        "    n_estimators=200,\n",
        "    learning_rate=0.05,\n",
        "    max_depth=5,\n",
        "    random_state=42\n",
        ")\n",
        "# GradientBoosting builds trees sequentially, correcting previous errors\n",
        "# Best model for this dataset based on testing\n",
        "\n",
        "models = {\n",
        "    'Logistic Regression' : logreg,\n",
        "    'Random Forest'       : rf,\n",
        "    'Gradient Boosting'   : gb,\n",
        "}\n",
        "\n",
        "# ── 8. K-Fold Cross-Validation Metrics ──────────────────────\n",
        "scoring = ['accuracy', 'precision', 'recall', 'f1', 'roc_auc']\n",
        "\n",
        "def run_kfold(model, X, y, cv, model_name):\n",
        "    results = cross_validate(model, X, y, cv=cv, scoring=scoring,\n",
        "                             return_train_score=False)\n",
        "    print(f\"\\n{'='*55}\")\n",
        "    print(f\"  {model_name}  —  {cv.n_splits}-Fold Cross-Validation\")\n",
        "    print(f\"{'='*55}\")\n",
        "    metric_map = {\n",
        "        'Accuracy' : results['test_accuracy'],\n",
        "        'Precision': results['test_precision'],\n",
        "        'Recall'   : results['test_recall'],\n",
        "        'F1-Score' : results['test_f1'],\n",
        "        'ROC-AUC'  : results['test_roc_auc'],\n",
        "    }\n",
        "    for name, scores in metric_map.items():\n",
        "        print(f\"  {name:<12}  Mean: {scores.mean():.4f}  ±  Std: {scores.std():.4f}\")\n",
        "    return results\n",
        "\n",
        "all_results = {}\n",
        "for name, model in models.items():\n",
        "    all_results[name] = run_kfold(model, X, y, skf, name)\n",
        "\n",
        "# ── 9. Model Comparison Bar Chart ───────────────────────────\n",
        "print(\"\\n\\nGenerating model comparison chart...\")\n",
        "metric_names = ['accuracy', 'precision', 'recall', 'f1', 'roc_auc']\n",
        "labels = ['Accuracy', 'Precision', 'Recall', 'F1', 'ROC-AUC']\n",
        "model_names = list(models.keys())\n",
        "x = np.arange(len(labels))\n",
        "width = 0.25\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(13, 6))\n",
        "colors = ['#4C72B0', '#55A868', '#C44E52']\n",
        "\n",
        "for i, (mname, color) in enumerate(zip(model_names, colors)):\n",
        "    means = [all_results[mname][f'test_{m}'].mean() for m in metric_names]\n",
        "    bars = ax.bar(x + i * width, means, width, label=mname, color=color, alpha=0.85)\n",
        "    for bar, val in zip(bars, means):\n",
        "        ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.005,\n",
        "                f'{val:.3f}', ha='center', va='bottom', fontsize=8)\n",
        "\n",
        "ax.set_xlabel('Metric')\n",
        "ax.set_ylabel('Score')\n",
        "ax.set_title('Model Comparison — 10-Fold Cross-Validation')\n",
        "ax.set_xticks(x + width)\n",
        "ax.set_xticklabels(labels)\n",
        "ax.set_ylim(0, 1.08)\n",
        "ax.legend()\n",
        "ax.grid(axis='y', alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# ── 10. Aggregated Confusion Matrices ───────────────────────\n",
        "def plot_confusion_matrix(model, X, y, cv, model_name):\n",
        "    # cross_val_predict: each sample predicted when it was in test fold\n",
        "    y_pred = cross_val_predict(model, X, y, cv=cv)\n",
        "    cm = confusion_matrix(y, y_pred)\n",
        "\n",
        "    plt.figure(figsize=(6, 5))\n",
        "    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',\n",
        "                xticklabels=['No Outbreak', 'Outbreak'],\n",
        "                yticklabels=['No Outbreak', 'Outbreak'],\n",
        "                annot_kws={'size': 14})\n",
        "    plt.title(f'Confusion Matrix — {model_name}\\n({cv.n_splits}-Fold CV, Aggregated)',\n",
        "              fontsize=12)\n",
        "    plt.xlabel('Predicted', fontsize=11)\n",
        "    plt.ylabel('Actual', fontsize=11)\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    TN, FP, FN, TP = cm.ravel()\n",
        "    print(f\"\\n--- {model_name} Aggregated CM Breakdown ---\")\n",
        "    print(f\"  True Negatives  (TN): {TN:<5} correctly predicted NO outbreak\")\n",
        "    print(f\"  False Positives (FP): {FP:<5} predicted outbreak, but wasn't (false alarm)\")\n",
        "    print(f\"  False Negatives (FN): {FN:<5} missed actual outbreaks ⚠️  (most critical)\")\n",
        "    print(f\"  True Positives  (TP): {TP:<5} correctly predicted outbreak\")\n",
        "    print(f\"  Sensitivity (Recall): {TP/(TP+FN):.4f}\")\n",
        "    print(f\"  Specificity:          {TN/(TN+FP):.4f}\")\n",
        "\n",
        "for name, model in models.items():\n",
        "    plot_confusion_matrix(model, X, y, skf, name)\n",
        "\n",
        "# ── 11. Per-Fold Confusion Matrices (Best Model: Gradient Boosting) ──\n",
        "print(\"\\n--- Per-Fold Confusion Matrices (Gradient Boosting) ---\")\n",
        "print(f\"{'Fold':<6} {'TN':<6} {'FP':<6} {'FN':<6} {'TP':<6} {'Recall':<8} {'AUC'}\")\n",
        "for fold, (train_idx, test_idx) in enumerate(skf.split(X, y), 1):\n",
        "    X_tr, X_te = X.iloc[train_idx], X.iloc[test_idx]\n",
        "    y_tr, y_te = y.iloc[train_idx], y.iloc[test_idx]\n",
        "    gb.fit(X_tr, y_tr)\n",
        "    y_p = gb.predict(X_te)\n",
        "    cm = confusion_matrix(y_te, y_p)\n",
        "    TN, FP, FN, TP = cm.ravel()\n",
        "    auc = roc_auc_score(y_te, gb.predict_proba(X_te)[:, 1])\n",
        "    recall = TP / (TP + FN) if (TP + FN) > 0 else 0\n",
        "    print(f\"  {fold:<4} {TN:<6} {FP:<6} {FN:<6} {TP:<6} {recall:<8.4f} {auc:.4f}\")\n",
        "\n",
        "# ── 12. Feature Importance (Random Forest) ──────────────────\n",
        "rf.fit(X, y)\n",
        "importances = pd.Series(rf.feature_importances_, index=features).sort_values(ascending=True)\n",
        "\n",
        "plt.figure(figsize=(9, 6))\n",
        "colors_fi = ['#C44E52' if i >= len(importances) - 3 else '#4C72B0'\n",
        "             for i in range(len(importances))]\n",
        "importances.plot(kind='barh', color=colors_fi)\n",
        "plt.title('Feature Importance — Random Forest\\n(Red = Top 3 Features)', fontsize=12)\n",
        "plt.xlabel('Importance Score')\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"\\nTop 5 most important features:\")\n",
        "print(importances.sort_values(ascending=False).head(5).to_string())\n",
        "\n",
        "# ── 13. Heatmap — Monthly Cases by District ─────────────────\n",
        "plt.figure(figsize=(14, 8))\n",
        "heatmap_data = df.pivot_table(index='district', columns='mon',\n",
        "                               values='Cases', aggfunc='sum').fillna(0)\n",
        "sns.heatmap(heatmap_data, cmap='Reds', linewidths=0.2)\n",
        "plt.title('Monthly Cases Heatmap by District', fontsize=13)\n",
        "plt.xlabel('Month')\n",
        "plt.ylabel('District')\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# ── 14. Time-Series — Total Cases per Month ─────────────────\n",
        "monthly_cases = df.groupby('mon')['Cases'].sum()\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.plot(monthly_cases.index, monthly_cases.values, marker='o',\n",
        "         color='steelblue', linewidth=2, markersize=7)\n",
        "plt.fill_between(monthly_cases.index, monthly_cases.values, alpha=0.15, color='steelblue')\n",
        "plt.title('Total Cases per Month (All Years Combined)', fontsize=13)\n",
        "plt.xlabel('Month')\n",
        "plt.ylabel('Total Cases')\n",
        "plt.xticks(range(1, 13), ['Jan','Feb','Mar','Apr','May','Jun',\n",
        "                            'Jul','Aug','Sep','Oct','Nov','Dec'])\n",
        "plt.grid(True, alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# ── 15. Early Warning — High Risk Districts ─────────────────\n",
        "# Train final Gradient Boosting on full dataset\n",
        "gb.fit(X, y)\n",
        "df['Outbreak_Prob'] = gb.predict_proba(X)[:, 1]\n",
        "\n",
        "# Get most recent record per district for prediction\n",
        "latest = df.sort_values(['year','mon','day']).groupby('district').last().reset_index()\n",
        "latest_X = latest[features].copy()\n",
        "for col in features:\n",
        "    latest_X[col] = pd.to_numeric(latest_X[col], errors='coerce')\n",
        "latest_X = latest_X.fillna(latest_X.mean())\n",
        "latest['Outbreak_Prob'] = gb.predict_proba(latest_X)[:, 1]\n",
        "\n",
        "high_risk = latest[latest['Outbreak_Prob'] > 0.7].sort_values(\n",
        "    'Outbreak_Prob', ascending=False)\n",
        "\n",
        "print(f\"\\n{'='*55}\")\n",
        "print(f\"  HIGH RISK DISTRICTS (Outbreak Probability > 70%)\")\n",
        "print(f\"{'='*55}\")\n",
        "print(f\"{'District':<30} {'State':<20} {'Prob'}\")\n",
        "print(\"-\" * 60)\n",
        "for _, row in high_risk.iterrows():\n",
        "    print(f\"  {row['district']:<28} {row['state_ut']:<20} {row['Outbreak_Prob']:.3f}\")\n",
        "\n",
        "print(f\"\\nTotal high-risk districts: {len(high_risk)}\")\n",
        "print(\"\\nDone.\")"
      ]
    }
  ]
}