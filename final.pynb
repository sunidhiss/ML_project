            "text/html": [
              "\n",
              "     <input type=\"file\" id=\"files-a4695117-30c5-41f2-a848-a9d89957d2b1\" name=\"files[]\" multiple disabled\n",
              "        style=\"border:none\" />\n",
              "     <output id=\"result-a4695117-30c5-41f2-a848-a9d89957d2b1\">\n",
