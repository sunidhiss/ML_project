            "  Srinagar                     Jammu and Kashmir    0.771\n",
            "  Kadapa                       Andhra Pradesh       0.756\n",
            "  Keonjhar                     Odisha               0.755\n",
            "  Kolasib                      Mizoram              0.744\n",
            "  Koraput                      Odisha               0.736\n",
            "  Balodabazar                  Chhattisgarh         0.735\n",
            "  Valsad                       Gujarat              0.732\n",
            "  Pratap Nagar                 Uttarakhand          0.719\n",
            "  East Imphal West Imphal      Manipur              0.713\n",
