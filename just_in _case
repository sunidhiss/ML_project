        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.cluster import KMeans\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from google.colab import files\n",
        "\n",
        "# 1. Upload Excel file\n",
        "uploaded = files.upload()\n",
        "\n",
        "# 2. Load Excel file\n",
        "df = pd.read_excel('Final_data.xlsx')\n",
        "\n",
        "# 3. Select numeric columns for clustering (using the same features as in your K-means cell)\n",
        "features = [\n",
        "    'Cases',\n",
        "    'Deaths',\n",
        "    'Temp',\n",
        "    'preci',\n",
        "    'LAI',\n",
        "    'Latitude',\n",
        "    'Longitude'\n",
        "]\n",
        "\n",
        "X = df[features].copy()\n",
        "\n",
        "# Convert columns to numeric, coercing errors to NaN\n",
        "for col in features:\n",
        "    X[col] = pd.to_numeric(X[col], errors='coerce')\n",
        "\n",
        "# 4. Handle missing values (using the same method as in your K-means cell)\n",
        "X = X.fillna(X.mean())\n",
        "\n",
        "# 5. Standardize the data\n",
        "schaler = StandardScaler()\n",
        "X_scaled = schaler.fit_transform(X)\n",
        "\n",
        "# 6. Apply the Elbow method to find optimal K\n",
        "inertia = []\n",
        "# Try K values from 1 to 10 (you can adjust this range)\n",
        "for i in range(1, 11):\n",
        "    kmeans = KMeans(n_clusters=i, random_state=42, n_init='auto')\n",
        "    kmeans.fit(X_scaled)\n",
        "    inertia.append(kmeans.inertia_)\n",
        "\n",
        "# Plot the Elbow Curve\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.plot(range(1, 11), inertia, marker='o')\n",
        "plt.title('Elbow Method for Optimal K')\n",
        "plt.xlabel('Number of Clusters (K)')\n",
        "plt.ylabel('Inertia')\n",
        "plt.xticks(range(1, 11))\n",
        "plt.grid(True)\n",
        "plt.show()\n",
        "\n",
        "print(\"Look for the 'elbow' point in the graph, where the decrease in inertia starts to slow down significantly. This point is often considered a good indication of the optimal number of clusters (K).\")\n",
        "print(\"Based on your assessment, the optimal K value is 3.\")\n"
      ],
