        "# 1. Upload Excel file\n",
        "from google.colab import files\n",
        "uploaded = files.upload()\n",
        "\n",
        "# 2. Read Excel file\n",
        "import pandas as pd\n",
        "\n",
        "df = pd.read_excel('Final_data.xlsx')\n",
        "print(df.head())\n",
        "\n",
        "# 3. Select numeric columns for clustering\n",
        "features = [\n",
        "    'Cases',\n",
        "    'Deaths',\n",
        "    'Temp',\n",
        "    'preci',\n",
        "    'LAI',\n",
        "    'Latitude',\n",
        "    'Longitude'\n",
        "]\n",
        "\n",
        "X = df[features].copy()#maintaining original dataset\n",
        "\n",
        "# Convert columns to numeric, coercing errors to NaN\n",
        "for col in features:\n",
        "    X[col] = pd.to_numeric(X[col], errors='coerce')\n",
        "\n",
        "# 4. Handle missing values\n",
        "X = X.fillna(X.mean())\n",
        "\n",
        "# Update df with the cleaned numeric features before clustering\n",
        "df[features] = X[features]\n",
        "\n",
        "# 5. Standardize the data\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "\n",
        "schaler = StandardScaler()\n",
        "X_scaled = schaler.fit_transform(X)\n",
        "\n",
        "# 6. K-Means clustering (K = 3)\n",
        "from sklearn.cluster import KMeans\n",
        "\n",
        "kmeans = KMeans(n_clusters=3, random_state=42, n_init='auto')\n",
        "df['Cluster'] = kmeans.fit_predict(X_scaled)\n",
        "\n",
        "\n",
        "#addition\n",
        "cluster_summary = df.groupby('Cluster')[[\n",
        "    'Cases', 'Deaths', 'Temp', 'preci', 'LAI'\n",
        "]].mean()\n",
        "\n",
        "print(cluster_summary)\n",
        "\n",
        "print(pd.crosstab(df['Cluster'], df['Disease']))\n",
        "# 7. Check results\n",
        "print(df[['Cluster'] + features].head())\n",
        "\n",
        "# 8. Save clustered data to Excel\n",
        "output_file = 'clustered_outbreak_data.xlsx'\n",
        "df.to_excel(output_file, index=False)\n",
        "\n",
        "# 9. Download the Excel file\n",
        "files.download(output_file)\n",
        "\n",
        "# 10. Plot clusters using location\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "plt.scatter(df['Longitude'], df['Latitude'], c=df['Cluster'], cmap='viridis')\n",
        "plt.xlabel('Longitude')\n",
        "plt.ylabel('Latitude')\n",
        "plt.title('Disease Outbreak Clusters (K = 3)')\n",
        "plt.colorbar(label='Cluster')\n",
        "plt.show()\n"
